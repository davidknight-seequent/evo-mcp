# Set to 1 to enable debug logging to context.log, or 0 to disable it. You can also set this in your environment or override it in the MCP config for your client.
DEBUG=0

# MCP Transport Mode
# Choose the transport protocol for the MCP server:
#   - "stdio" (default): Standard input/output, used by VS Code, Cursor, Claude Desktop
#   - "http": HTTP with SSE, accessible via HTTP requests (useful for remote access or testing)
MCP_TRANSPORT=stdio

# HTTP Transport Configuration (only used if MCP_TRANSPORT=http)
MCP_HTTP_HOST=localhost
MCP_HTTP_PORT=5000

# ---------------------------------------------
# Evo authentication (choose one auth method)
# ---------------------------------------------
# See "Configure your Evo credentials" in the README.
# Uncomment the environment variables for your chosen auth method.
# These values can also be set/overridden in your MCP client config.

# 1) Native app credentials (interactive user sign-in)
#    Use this for local development with a user account.
# AUTH_METHOD=native_app
# EVO_CLIENT_ID=your-native-app-client-id
# EVO_REDIRECT_URL=http://localhost:3000/signin-callback

# 2) Client credentials (service-to-service, no user sign-in)
#    Use this for automation, CI/CD, and background services.
# AUTH_METHOD=client_credentials
# EVO_CLIENT_ID=your-service-client-id
# EVO_CLIENT_SECRET=your-service-client-secret


MCP_TOOL_FILTER=all
# Search path for local data files. Point this to local data you want tools to
# be able to access.
# Defaults to "data" in the repo root.
# EVO_LOCAL_DATA_DIR=D:\data\my-data-files\

# Authority URLs for key systems, you shouldn't need to change these.
ISSUER_URL=https://ims.bentley.com
EVO_DISCOVERY_URL=https://discover.api.seequent.com

# Example Agent Config
EVO_AGENT_MODEL=gemini-2.5-flash

# Example agent ADK config
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
